{
    "arduino.useArduinoCli": true,
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "files.autoSave": "onFocusChange",
    "[dart]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.rulers": [
            140
        ],
        "editor.selectionHighlight": false,
        "editor.suggestSelection": "first",
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "off"
    },
    "makefile.makePath": "/usr/bin/make",
    "makefile.makefilePath": "kernel/Makefile",
    "C_Cpp.files.exclude": {
        "**/.vscode": true,
        "**/.vs": true
    },
    "workbench.colorTheme": "Tokyo Night",
    "workbench.colorCustomizations": {
        // インデントガイド（非アクティブ）
        "editorIndentGuide.background1": "#3b4261",
        "editorIndentGuide.background2": "#565f89",
        "editorIndentGuide.background3": "#414868",
        "editorIndentGuide.background4": "#24283b",
        "editorIndentGuide.background5": "#1a1b26",
        "editorIndentGuide.background6": "#16161e",

        // アクティブなインデントガイド（明るめの差し色）
        "editorIndentGuide.activeBackground1": "#7aa2f7",
        "editorIndentGuide.activeBackground2": "#bb9af7",
        "editorIndentGuide.activeBackground3": "#9ece6a",
        "editorIndentGuide.activeBackground4": "#e0af68",
        "editorIndentGuide.activeBackground5": "#f7768e",
        "editorIndentGuide.activeBackground6": "#7dcfff"
    },
    "dart.lineLength": 140,
    "synthwave84.brightness": 0.5,
    "editor.suggest.filterGraceful": false,
    "editor.suggest.preview": true,
    "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
    "vscode-neovim.neovimExecutablePaths.linux": "vim",
    "vscode-neovim.neovimExecutablePaths.win32": "vim",
    "python.defaultInterpreterPath": "/Users/takuto1127/.pyenv/versions/3.10.16/bin/python",
    "dart.devToolsBrowser": "default",
    "gitlens.advanced.messages": {
        "suppressCreatePullRequestPrompt": true
    },
    "cursor.cpp.disabledLanguages": [
        "plaintext",
        "markdown",
        "scminput",
        "python"
    ],
    "terminal.explorerKind": "external",
    "terminal.external.linuxExec": "zsh",
    "terminal.integrated.tabs.title": "${process}-${task}",
    "terminal.integrated.minimumContrastRatio": 7,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "workbench.activityBar.orientation": "vertical",
    "git.autofetch": true,
    "vscode-pets.throwBallWithMouse": true,
    "editor.inlineSuggest.suppressSuggestions": true,
    "vscode-pets.petSize": "medium",
    "vscode-pets.theme": "forest",
    "terminal.external.osxExec": "",
    "editor.fontFamily": "Menlo, Monaco, 'Courier New', monospace, MesloLGS NF",
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false,
        "python": true
    },
    "discord.idleTimeout": 600,
    "lldb.library": "/Applications/Xcode.app/Contents/SharedFrameworks/LLDB.framework/Versions/A/LLDB",
    "lldb.launch.expressions": "native",
    "print.folder.fileNames": true,
    "print.folder.include": [],
    "print.folder.exclude": [
        "{bin,obj,out}",
        "node_modules",
        "data",
        "**/*.{bin,exe,dll,hex,pdb,pdf,pfx,png,jpg,gif,bmp,suo,design}"
    ],
    "print.folder.maxLines": 1200,
    "print.folder.maxFiles": 30,
    "print.folder.includeFileList": false,
    "cursor.cpp.enablePartialAccepts": true,
    "cursor.chat.showSuggestedFiles": true,
    "redhat.telemetry.enabled": true,
    "workbench.iconTheme": "catppuccin-mocha",
    "editor.minimap.enabled": false,
    "hediet.vscode-drawio.resizeImages": null,
    "leetcode.workspaceFolder": "/Users/takuto1127/.leetcode",
    "leetcode.defaultLanguage": "pythogv",
    "window.commandCenter": 1,
    "cSpell.userWords": [
        "dists",
        "jcenter",
        "prefs",
        "stdlib"
    ],
    "debug.javascript.debugByLinkOptions": "on",
    "terminal.integrated.allowChords": false,
    "diffEditor.ignoreTrimWhitespace": true,
    "git.confirmSync": false,
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.nextEditSuggestions.fixes": true,
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.chat.agent.thinkingTool": true,
    "markdown.marp.html": "all",
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.pdf": "default"
    },
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "pubspec.yaml": "pubspec.lock,pubspec_overrides.yaml,.packages,.flutter-plugins,.flutter-plugins-dependencies,.metadata",
        "*.dart": "${capture}.g.dart",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "gitlens.advanced.similarityThreshold": 50,
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "githubPullRequests.pullBranch": "never",
    "geminicodeassist.project": "voltaic-edge-6j1cz",
    "indentRainbow.indicatorStyle": "light",
    "indentRainbow.lightIndicatorStyleLineWidth": 0.2,
    "indentRainbow.ignoreLinePatterns": [
        "^\\s*#.*",  // プリプロセッサ行を無視
        "/[ \t]* [*]/g",
        "/[ \t]+[/]{2}/g"
    ],
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "geminicodeassist.displayInlineContextHint": false,
    "git.blame.editorDecoration.enabled": true,
    "security.promptForLocalFileProtocolHandling": false,
    "chat.mcp.gallery.enabled": true,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "chat.agent.maxRequests": 300,
    "chat.tools.terminal.autoApprove": {
        "make": true
    },
    "latex-workshop.latex.autoBuild.run": "never",
}